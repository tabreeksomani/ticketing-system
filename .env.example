# Copy this to ".env" to configure the app. All variables have sane local
# defaults, so this file is optional for local development - but set a real
# JWT_SECRET before any real deployment (see below).

# Postgres connection string. Defaults to a local "ticketing_system" database
# on the default port with no auth if unset.
DATABASE_URL=postgres://localhost:5432/ticketing_system

# Signing key for login tokens. Falls back to a random value generated at
# process startup if unset - fine for local dev (just means restarting the
# server invalidates existing sessions), but set a real fixed value for any
# real deployment so tokens survive a restart/redeploy.
JWT_SECRET=

# Set to "true" when pointing DATABASE_URL at Azure Database for PostgreSQL (or
# any host that requires SSL) - local Postgres doesn't need this.
DATABASE_SSL=false

# Port the Express server listens on.
PORT=8000

# When set to 1, API error responses include the real underlying error message
# instead of a generic one. Turn this OFF again once you're done debugging -
# don't leave it on in production, since it can reveal internal details.
APP_DEBUG=0
