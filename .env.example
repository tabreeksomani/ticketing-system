# Copy this to ".env" to configure the app. All variables have sane local
# defaults, so this file is optional for local development - but set a real
# JWT_SECRET before any real deployment (see below).

# Postgres connection string. Matches the postgres/postgres credentials and
# port 5433 in docker-compose.yml, which `npm run setup` starts automatically
# (5433, not 5432, to avoid clashing with a Postgres install some machines
# already have running natively on the default port) - change this if you're
# pointing at a different Postgres instance instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/ticketing_system

# Signing key for login tokens. Falls back to a random value generated at
# process startup if unset - fine for local dev (just means restarting the
# server invalidates existing sessions), but set a real fixed value for any
# real deployment so tokens survive a restart/redeploy.
JWT_SECRET=

# Set to "true" when pointing DATABASE_URL at Azure Database for PostgreSQL (or
# any host that requires SSL) - local Postgres doesn't need this.
DATABASE_SSL=false

# Connection pooling & timeout configurations (optional, commented out below with defaults)
# DATABASE_POOL_MAX=10
# DATABASE_POOL_MIN=4
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
# DATABASE_POOL_MAX_USES=
# DATABASE_STATEMENT_TIMEOUT_MS=60000
# DATABASE_LOCK_TIMEOUT_MS=10000
# DATABASE_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000

# Port the Express server listens on.
PORT=8000

# When set to 1, API error responses include the real underlying error message
# instead of a generic one. Turn this OFF again once you're done debugging -
# don't leave it on in production, since it can reveal internal details.
APP_DEBUG=0
